{
  "model_name": "ppo_single_asset_ablation_basic",
  "paths": {
    "checkpoint_root": "checkpoints",
    "log_root": "logs",
    "ticker_list_path": null,
    "asset_universe_path": null
  },
  "resume": {
    "path": null,
    "auto_resume": false
  },
  "dataset": {
    "root_path": "Data/polygon",
    "data_path": "data_raw_1m",
    "start_date": null,
    "split": "train",
    "context_len": 512,
    "use_time_features": true,
    "rolling_window": 252,
    "train_split": 0.7,
    "test_split": 0.15,
    "tickers": null,
    "regular_hours_only": true,
    "timeframe": "15min"
  },
  "env": {
    "episode_length_steps": 2048,
    "n_envs": 8,
    "transaction_cost_start": 0.0005,
    "transaction_cost_end": 0.0005,
    "transaction_cost_steps": 0,
    "transaction_cost_schedule_timesteps": 6000000,
    "transaction_cost_warmup": 0,
    "include_wealth": false,
    "include_asset_id": false,
    "reward_scale": 10.0,
    "allow_short": true,
    "action_mode": "discrete_3"
  },
  "ppo": {
    "feature_mode": "basic",
    "share_features_extractor": false,
    "net_arch_pi": [256, 256],
    "net_arch_vf": [512, 512],
    "rollout_length_steps": 1024,
    "total_timesteps": 2000000,
    "learning_rate": 0.0003,
    "n_epochs": 6,
    "batch_size": 256,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_range": 0.2,
    "ent_coef_start": 0.02,
    "ent_coef_end": 0.0005,
    "ent_decay_steps": 1000000,
    "ent_warmup_fraction": 0.0,
    "vf_coef": 0.5,
    "max_grad_norm": 0.5,
    "target_kl": 0.015,
    "policy_learning_rate": 0.0003
  },
  "evaluation": {
    "episodes": 8,
    "episode_len": 1024,
    "every_steps": 2048,
    "checkpoint_every_steps": 20000,
    "moving_average_window": 20
  }
}
